{
  "name": "verreaux-scrape",
  "version": "0.1.0",
  "description": "Multi-source manhwa/manga scraper producing Verreaux-compatible ZIPs",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/vajohn/verreaux-scraper.git"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "bin": {
    "verreaux-scrape": "./dist/cli/index.js",
    "verreaux-scrape-pi": "./scripts/scrape-pi.mjs"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node scripts/copy-assets.mjs",
    "postbuild": "node -e \"require('fs').chmodSync('dist/cli/index.js', 0o755)\"",
    "prepare": "npm run build",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@types/archiver": "^7.0.0",
    "adm-zip": "^0.5.16",
    "archiver": "^7.0.1",
    "better-sqlite3": "^11.9.1",
    "bottleneck": "^2.19.5",
    "cheerio": "^1.0.0",
    "chokidar": "^4.0.3",
    "commander": "^13.1.0",
    "got": "^14.4.6",
    "jszip": "^3.10.1",
    "pg": "^8.21.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "playwright": "^1.52.0",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "sharp": "^0.34.5",
    "tough-cookie": "^5.1.2",
    "uuid": "^11.1.0",
    "web-push": "^3.6.7",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.15.17",
    "@types/pg": "^8.20.0",
    "@types/uuid": "^10.0.0",
    "@types/web-push": "^3.6.4",
    "@typescript-eslint/eslint-plugin": "^8.32.1",
    "@typescript-eslint/parser": "^8.32.1",
    "eslint": "^9.26.0",
    "prettier": "^3.5.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.3"
  }
}
